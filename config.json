{
  "server": {
      "port": "8080",
      "host": "localhost",
      "read_timeout": 15000000000,
      "write_timeout": 15000000000
  },
  "paths": {
      "root_dir": "",
      "templates_dir": "templates",
      "static_dir": "static",
      "data_dir": "data"
  },
  "security": {
      "allowed_origins": ["*"],
      "rate_limits": {
          "api": "100-M",
          "static": "1000-M",
          "default": "60-M"
      }
  },
  "cors": {
      "origins": ["*"],
      "methods": ["GET", "HEAD"],
      "response_headers": ["Content-Type"],
      "max_age_seconds": 3600
  },
  "external": {
      "google_sheets_url": "https://docs.google.com/spreadsheets/d/129l5jEzO1_qIkpa43AeqKFzwfDglURjLUVPWfiR4n2c/edit?gid=0#gid=0",
      "project_id": "swingsociety-backend"
  },
  "environment": "development"
}