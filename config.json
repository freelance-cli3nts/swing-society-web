{
  "server": {
      "port": "8080",
      "host": "localhost",
      "read_timeout": 15000000000,
      "write_timeout": 15000000000
  },
  "firebase": {
    "credentials_file": "./swing-society-realtime-firebase-adminsdk.json"
  },  
  "paths": {
      "root_dir": "",
      "templates_dir": "templates",
      "static_dir": "static",
      "data_dir": "data"
  },
  "security": {
      "allowed_origins": ["*"],
      "rate_limits": {
          "api": "100-M",
          "static": "1000-M",
          "default": "60-M"
      },
      "csp_directives": "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https:; img-src 'self' https: data:; frame-src 'self' https://www.youtube.com; connect-src 'self' https:;"
  },
  "external": {
      "google_sheets_url": "https://docs.google.com/spreadsheets/d/129l5jEzO1_qIkpa43AeqKFzwfDglURjLUVPWfiR4n2c/edit?gid=0#gid=0",
      "project_id": "swingsociety-backend"
  },
  "environment": "development"
}